KHALTI_SECRET_KEY="test_secret_key_xxxxxxxxxxxxxxxxxxxx"
KHALTI_PUBLIC_KEY="test_public_key_xxxxxxxxxxxxxxxxxxxx"
KHALTI_API_URL="https://dev.khalti.com/api/v2"

